# HAI (Hyperspace AI) — lokaler LLM-Proxy.
# Kopieren nach  hai/.env  und mit deinem HAI-Key füllen.
# hai/.env liegt in .gitignore und wird NICHT eingecheckt.

HAI_BASE_URL=http://localhost:6655/litellm/v1
HAI_API_KEY=your-hai-key-here
# Default-Modell (überschreibbar pro Call). Beispiele:
#   anthropic--claude-4.6-sonnet   (empfohlen: dt. Reasoning, JSON)
#   gpt-5.5                        (OpenAI)
#   gemini-3.5-flash               (schnell/günstig)
HAI_MODEL=anthropic--claude-4.6-sonnet
