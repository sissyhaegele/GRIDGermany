# GRIDGermany - Broker-Konfiguration (Python-Seite)
# Kopieren nach  config.env  und mit den echten Werten füllen.
# config.env liegt in .gitignore und wird NICHT eingecheckt.
#
# Broker-Umzug = nur diese Werte ändern (+ dashboards/config.js fürs Dashboard).

SOLACE_HOST=your-broker.messaging.solace.cloud
SOLACE_VPN_NAME=your-vpn
SOLACE_USERNAME=your-username
SOLACE_PASSWORD=your-password

# Ports sind bei Solace Cloud standardisiert und müssen i.d.R. nicht geändert
# werden (nur bei abweichendem Broker). Optional überschreibbar:
# SOLACE_PORT=8883          # MQTT/TLS  (Sensoren, Consumer, demo_scenario Subscribe)
# SOLACE_REST_PORT=9443     # REST      (agentActionTaken / Alarme publizieren)
